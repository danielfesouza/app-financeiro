# Supabase — encontre estes valores em: https://supabase.com/dashboard → seu projeto → Settings → API
# A anon key é a chave PÚBLICA (publishable). NUNCA coloque a service_role key aqui.
NEXT_PUBLIC_SUPABASE_URL=https://<seu-project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<sua-anon-key-publica>
